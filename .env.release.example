# Copy to `.env.release` (gitignored) and fill in real values, then:
#   source .env.release && npm run release:mac && npm run publish:mac

# ── Apple notarization (App Store Connect API key) ─────────────────────────
# electron-builder + @electron/notarize read these automatically.
# APPLE_API_KEY is the absolute path to the .p8 file you downloaded from
# https://appstoreconnect.apple.com/access/integrations/api
export APPLE_API_KEY="$HOME/Documents/arco-certificates/AuthKey_9B4LX8FVZV.p8"
export APPLE_API_KEY_ID="9B4LX8FVZV"
export APPLE_API_ISSUER="e75e4d35-4119-49c7-849c-c854b997cde3"
export APPLE_TEAM_ID="Z6N26D2QCX"

# Let electron-builder auto-discover the "Developer ID Application" cert
# from your login Keychain. Verify it's there with:
#   security find-identity -v -p codesigning
export CSC_IDENTITY_AUTO_DISCOVERY=true

# ── Cloudflare R2 (upload script only — NOT bundled with the app) ──────────
export R2_ACCESS_KEY_ID="..."
export R2_SECRET_ACCESS_KEY="..."
export R2_ENDPOINT="https://1d60cdc73e95f905119cf433d8a994f6.r2.cloudflarestorage.com"
export R2_BUCKET="arco-updates"
